# === Database (Supabase Postgres) ===
# Pooled connection (transaction mode, pgbouncer) — dipakai runtime app
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (session mode) — dipakai Prisma migrate
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres"

# === Better Auth ===
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
BETTER_AUTH_SECRET="<random-secret>"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# === Cloudinary ===
CLOUDINARY_CLOUD_NAME="<cloud-name>"
CLOUDINARY_API_KEY="<api-key>"
CLOUDINARY_API_SECRET="<api-secret>"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="<cloud-name>"

# === AI features (tutor, writing feedback, content generators) ===
# Set ANY ONE of these to turn AI features on; leave all empty for the non-AI
# fallback. Priority order: GROQ > GEMINI > OPENAI > ANTHROPIC.
# Recommended: Groq — free & fast. Key: https://console.groq.com/keys
GROQ_API_KEY=""
# Optional alternatives:
GEMINI_API_KEY=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
# Optional: override the model for whichever provider is active.
# e.g. Groq: llama-3.3-70b-versatile · Gemini: gemini-2.0-flash · OpenAI: gpt-4o-mini
AI_MODEL=""
